{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LIMEN Evidence Envelope",
  "type": "object",
  "required": ["source_hash", "extraction_timestamp", "classification_tags", "cluster_id", "review_status", "c2pa_manifest", "scitt_receipt"],
  "properties": {
    "source_hash": {
      "type": "string",
      "format": "uri",
      "description": "SHA-256 hash of the original source material."
    },
    "extraction_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when extraction completed."
    },
    "classification_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["AI-bias", "procurement-risk", "surveillance-use", "other"]
      },
      "description": "RATS role tags applied to the record."
    },
    "cluster_id": {
      "type": "string",
      "description": "Identifier of the cluster this record belongs to."
    },
    "review_status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"],
      "description": "Result of human legal review."
    },
    "c2pa_manifest": {
      "type": "string",
      "format": "uri",
      "description": "URI to C2PA manifest containing provenance information."
    },
    "scitt_receipt": {
      "type": "string",
      "format": "uri",
      "description": "URI to SCITT transparency receipt."
    },
    "review_log": {
      "type": "string",
      "description": "Optional free-text notes from legal review."
    }
  },
  "additionalProperties": false
}