{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LIMEN Attestation Envelope Schema",
  "type": "object",
  "properties": {
    "profileVersion": { "type": "string" },
    "nonClaimsDisclaimer": { "type": "string" },
    "evidenceRoles": {
      "type": "object",
      "properties": {
        "record": { "type": "string" },
        "assert": { "type": "string" },
        "test": { "type": "string" },
        "support": { "type": "string" }
      }
    },
    "provenanceStandards": {
      "type": "object",
      "properties": {
        "verifiableCredentials": { "type": "string", "format": "uri" },
        "scttReceipts": { "type": "string", "format": "uri" },
        "c2paManifest": { "type": "string", "format": "uri" }
      }
    },
    "classificationPipeline": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifactManifest": {
      "type": "object",
      "properties": {
        "profilePath": { "type": "string" },
        "schemaPath": { "type": "string" },
        "statusPath": { "type": "string" },
        "journalPath": { "type": "string" }
      }
    },
    "validationGovernance": { "type": "string" }
  },
  "required": [
    "profileVersion",
    "nonClaimsDisclaimer",
    "evidenceRoles",
    "provenanceStandards",
    "classificationPipeline",
    "artifactManifest",
    "validationGovernance"
  ]
}