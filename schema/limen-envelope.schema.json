{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Limen Envelope Profile Schema",
  "type": "object",
  "properties": {
    "profile_version": { "type": "string" },
    "observation_schema": { "type": "string" },
    "extraction_pipeline": { "type": "string" },
    "classification_rules": { "type": "string" },
    "review_workflow": { "type": "string" },
    "clustering_approach": { "type": "string" },
    "publication_targets": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["profile_version", "observation_schema", "extraction_pipeline", "classification_rules", "review_workflow", "clustering_approach", "publication_targets"]
}